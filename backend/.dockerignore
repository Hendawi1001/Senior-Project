# Exclude unnecessary files from Docker build context

# Git
.git
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Dev/test files
*.log
*.pot
*.mo
.env
.env.*
!.env.example

# SQLite (will use Docker volume)
db.sqlite3
*.sqlite3-journal

# Uploaded media (will use Docker volume)
media/

# Static files (will be collected by collectstatic)
staticfiles/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Simulation/data files (large - not needed in container)
simulated_data.pt
